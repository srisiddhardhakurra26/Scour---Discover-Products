# Scour environment variables
# Copy to .env and fill in the keys you have. Adapters whose creds are missing
# are silently excluded from search (no error).

# eBay Browse API — https://developer.ebay.com/my/keys (free signup)
# Create an "Application" keyset, then use the Client ID + Client Secret.
EBAY_APP_ID=
EBAY_CERT_ID=

# Etsy v3 API — https://www.etsy.com/developers (free signup)
# Apply for an app; the API key string is what goes here.
ETSY_API_KEY=

# Best Buy Open API — https://developer.bestbuy.com (free signup)
BESTBUY_API_KEY=

# Optional AI providers. Scour works without them; Groq is tried first and
# Gemini is the fallback (and powers screenshot-based scraper repair).
GROQ_API_KEY=
GEMINI_API_KEY=

# Optional Reddit OAuth app. Without these, Reddit uses public JSON endpoints
# that are frequently rate-limited or blocked.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# Operational controls. Boolean flags accept 1/true/yes/on.
WATCHDOG_DISABLED=0
# WATCHDOG_INTERVAL_MS=86400000
ENRICH_DISABLED=0
ENRICH_OCR_DISABLED=0

# Optional bearer token for /api/mcp. Leave blank to keep that endpoint open.
MCP_API_KEY=

# Caddy deployment address, e.g. scour.example.com or :80 for local HTTP.
SITE_ADDRESS=:80
