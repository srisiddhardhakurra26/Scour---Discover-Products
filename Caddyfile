# SITE_ADDRESS comes from .env.
#   :80                       -> plain HTTP on the server's IP (quickest start)
#   203-0-113-5.sslip.io      -> free auto-HTTPS, no domain needed
#   scour.example.com         -> your own domain, auto-HTTPS
{$SITE_ADDRESS} {
	# Password gate — every visitor must log in. Share the username + password
	# only with people you want; withhold it from anyone you don't.
	# To change the password later, regenerate the bcrypt hash on the VM:
	#   sudo docker compose exec caddy caddy hash-password --plaintext 'NEWPASS'
	# then paste the new hash below and redeploy.
	basic_auth {
		scour $2a$10$AijdPxdyXz4luJQ8uyi1wOGG0xXCvx1rCBg0mVxX1QDF9JgAa59MS
	}

	reverse_proxy app:3000
}

# feedhub — a separate app sharing this VM, told apart by hostname. It runs as
# its own container (feedhub-app) joined to this Compose network, and brings up
# its own password login (APP_PASSWORD), so no Caddy basic_auth here. Deployed
# by .github/workflows/deploy-feedhub.yml. Caddy auto-issues its cert too.
feedhub.167-234-217-97.sslip.io {
	reverse_proxy feedhub-app:3000
}
